PORT=3000
API_PORT=3000

DATABASE_PASSWORD=change_me
DATABASE_URL=mongodb://root:change_me@mongo:27017/cyna?authSource=admin

ACCESS_TOKEN_SECRET_KEY=change_me
ACCESS_TOKEN_EXPIRE_TIME=1d

APP_BASE_URL=http://localhost:3000

# Origine(s) du frontend : utilisée pour le CORS et les liens dans les emails.
# Plusieurs origines possibles, séparées par des virgules.
FRONTEND_URL=http://localhost:5173

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_email@example.com
MAIL_PASSWORD=change_me
MAIL_FROM=no-reply@cyna.fr

STRIPE_SECRET_KEY=sk_test_change_me
# Secret de signature du webhook Stripe (dashboard Stripe → Developers → Webhooks).
# Endpoint a declarer : https://<votre-domaine>/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_change_me

# Taux de TVA applique aux commandes (fraction : 0.20 = 20%). Defaut 20% (France).
TVA_RATE=0.20

# Secret partage avec Vercel Cron : protege l'endpoint /api/cron/abonnements.
# Definir la meme valeur dans les variables d'environnement du projet Vercel ;
# Vercel ajoute alors automatiquement l'en-tete Authorization aux appels cron.
CRON_SECRET=change_me

# Monitoring d'erreurs Sentry (optionnel). Sans DSN, Sentry est desactive.
# Backend : SENTRY_DSN ; Frontend (Vite) : VITE_SENTRY_DSN.
SENTRY_DSN=

# Notifications push Web (VAPID). Generer les cles : node scripts/generate-vapid.js
# Sans ces variables, les push sont desactives (no-op).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:support@cyna.fr
